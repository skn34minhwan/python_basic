     "text": [
      "안녕하세요, 토끼님! 무엇을 도와드릴까요?\n",
      "안녕하세요, 곰님! 무엇을 도와드릴까요?\n",
      "안녕하세요, 여우님! 무엇을 도와드릴까요?\n",
      "죄송합니다, 오늘은 여기까지입니다!\n"
     ]
    }
   ],
   "source": [
    "# 손님 리스트 생성\n",
    "customers = ['토끼', '곰', '여우', '호랑이', '늑대']\n",
    "\n",
    "# 몇 번째 손님인지 세기 위한 변수\n",
    "count = 0\n",
    "\n",
    "for customer in customers:\n",
    "    print(f\"안녕하세요, {customer}님! 무엇을 도와드릴까요?\")\n",
    "    count += 1\n",
    "    \n",
    "    if count == 3:\n",
    "        print(\"죄송합니다, 오늘은 여기까지입니다!\")\n",
    "        break # 반복문 종료"
   ]
  }
 ],
